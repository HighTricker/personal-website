---
import Layout from '../../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';
import photos from '../../data/photos.json';
import PhotoLightbox from '../../components/PhotoLightbox.tsx';

const entry = await getEntry('pages', 'en/about');
if (!entry) {
  throw new Error('en/about.md not found in src/content/pages/');
}
const { Content } = await render(entry);
const { title, description } = entry.data;
---

<Layout title={title} description={description} locale="en">
  <article class="max-w-[680px] mx-auto px-4 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl mb-8 text-center">{title}</h1>
    <div class="article-content">
      <Content />
    </div>
  </article>

  <!-- 照片墙（所有屏幕统一 3 列；浏览器原生 lazy load；说明保留中文）-->
  <section class="max-w-[1200px] mx-auto px-4 pb-16">
    <div class="grid grid-cols-3 gap-1 md:gap-1.5">
      {photos.map(photo => (
        <button
          type="button"
          data-photo-filename={photo.filename}
          data-photo-caption={photo.caption}
          data-photo-note={photo.note}
          class="block aspect-square overflow-hidden bg-[var(--color-parchment)] cursor-pointer hover:opacity-80 transition-opacity"
          aria-label={photo.caption}
        >
          <img
            src={`/thumbs/${photo.filename.replace(/\.(jpe?g|png)$/i, '.webp')}`}
            alt={photo.caption}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </button>
      ))}
    </div>
  </section>

  <!-- React 岛屿：照片弹框（点击照片打开）-->
  <PhotoLightbox client:idle photos={photos} />
</Layout>

<style>
  .article-content :global(p) {
    line-height: 1.85;
    margin: 1.2em 0;
    font-size: 1.0625rem;
  }
  .article-content :global(h2) {
    font-size: 1.5rem;
    margin: 2em 0 0.6em;
    line-height: 1.3;
  }
  .article-content :global(h3) {
    font-size: 1.25rem;
    margin: 1.5em 0 0.5em;
  }
  .article-content :global(a) {
    color: var(--color-amethyst);
    text-decoration: underline;
  }
  .article-content :global(strong) {
    font-weight: bold;
  }
  .article-content :global(blockquote) {
    border-left: 4px solid var(--color-lavender);
    padding-left: 1em;
    margin: 1.2em 0;
    opacity: 0.85;
  }
  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 1em 0;
    padding-left: 1.5em;
  }
  .article-content :global(li) {
    margin: 0.4em 0;
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .article-content :global(p),
    .article-content :global(li) {
      font-size: 1.375rem;
    }
    .article-content :global(h2) {
      font-size: 2rem;
    }
    .article-content :global(h3) {
      font-size: 1.625rem;
    }
  }
</style>

---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { t } from '../../../i18n';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const data = article.data as { title: string; title_en?: string; date: Date; tags: string[]; summary: string };
const { title, title_en, date, tags, summary } = data;
const displayTitle = title_en || title;

const wordCount = (article.body ?? '').replace(/\s+/g, '').length;
const readingMinutes = Math.max(1, Math.round(wordCount / 300));

function formatDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}

const i18n = t('en');
const downloadHref = `/download/${article.id}.md`;
---

<Layout title={displayTitle} description={summary} locale="en">
  <article class="max-w-[680px] mx-auto px-4 py-12 md:py-16 relative">
    <a
      href={downloadHref}
      download
      aria-label={i18n.article.downloadMd}
      class="absolute top-4 right-4 text-[var(--color-charcoal)]/60 hover:text-[var(--color-amethyst)] transition-colors"
      title={i18n.article.downloadMd}
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
    </a>

    <h1 class="text-3xl md:text-4xl mb-3 leading-tight pr-12">{displayTitle}</h1>

    <div class="flex flex-wrap items-center gap-3 mb-8 text-xs text-[var(--color-charcoal)]/60">
      <span>{formatDate(date)}</span>
      <span>·</span>
      <span>{readingMinutes} {i18n.article.readingTimeUnit}</span>
      {i18n.article.chineseOnly && (
        <>
          <span>·</span>
          <span class="text-[var(--color-charcoal)]/40">{i18n.article.chineseOnly}</span>
        </>
      )}
      {tags.length > 0 && (
        <>
          <span>·</span>
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="px-2 py-0.5 rounded bg-[var(--color-parchment)]/50">{tag}</span>
            ))}
          </div>
        </>
      )}
    </div>

    <div class="article-content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .article-content :global(p) { line-height: 1.85; margin: 1.2em 0; font-size: 1.0625rem; }
  .article-content :global(h1) { font-size: 1.875rem; margin: 1.5em 0 0.5em; }
  .article-content :global(h2) { font-size: 1.5rem; margin: 2em 0 0.6em; line-height: 1.3; }
  .article-content :global(h3) { font-size: 1.25rem; margin: 1.5em 0 0.5em; }
  .article-content :global(h4) { font-size: 1.125rem; margin: 1.5em 0 0.5em; }
  .article-content :global(h5),
  .article-content :global(h6) { font-size: 1rem; margin: 1.2em 0 0.4em; }
  .article-content :global(a) { color: var(--color-amethyst); text-decoration: underline; }
  .article-content :global(strong) { font-weight: bold; }
  .article-content :global(blockquote) { border-left: 4px solid var(--color-lavender); padding-left: 1em; margin: 1.2em 0; opacity: 0.85; }
  .article-content :global(ul),
  .article-content :global(ol) { margin: 1em 0; padding-left: 1.5em; }
  .article-content :global(li) { margin: 0.4em 0; line-height: 1.7; }
  .article-content :global(code) {
    font-family: ui-monospace, SFMono-Regular, monospace;
    background: rgba(220, 215, 211, 0.5);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.92em;
  }
  .article-content :global(pre) {
    background: #f5f5f3;
    border: 1px solid var(--color-parchment);
    border-radius: 8px;
    padding: 1em;
    overflow-x: auto;
    margin: 1.2em 0;
  }
  .article-content :global(pre code) { background: transparent; padding: 0; font-size: 0.9rem; }
  .article-content :global(hr) { border: 0; border-top: 1px solid var(--color-parchment); margin: 2.5em 0; }
  .article-content :global(img) { max-width: 100%; border-radius: 8px; margin: 1.5em 0; }
</style>

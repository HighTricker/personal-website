---
import Layout from '../../../layouts/Layout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n';

const articles = await getCollection('articles', ({ data }) => !data.hidden);
const sorted = articles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const i18n = t('en');
---

<Layout
  title={i18n.articleListPage.title}
  description={i18n.articleListPage.description}
  locale="en"
>
  <section class="max-w-[1200px] mx-auto px-4 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl mb-8 text-center">{i18n.articleListPage.title}</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {sorted.map(article => (
        <ArticleCard article={article} locale="en" />
      ))}
    </div>
  </section>
</Layout>

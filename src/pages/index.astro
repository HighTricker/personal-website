---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import PlaceholderCard from '../components/PlaceholderCard.astro';
import MouseFireflies from '../components/MouseFireflies.tsx';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.hidden);
const sorted = articles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="AI 工程师和创作者">
  <!-- Hero：视频背景 + 萤火虫粒子岛屿 + 文字层 -->
  <section class="hero-section relative w-full overflow-hidden isolate">
    <video
      class="absolute inset-0 w-full h-full object-cover z-0"
      id="heroBgVideo"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/cloud.mp4" type="video/mp4" />
    </video>

    <MouseFireflies client:load />

    <div class="relative z-20 h-full flex flex-col items-center justify-center text-center px-4 gap-3">
      <p class="text-3xl md:text-5xl leading-tight text-[var(--color-charcoal)]/35">
        您好，我是 <span class="hero-hl">鲁家琪</span>
      </p>
      <p class="text-xl md:text-2xl text-[var(--color-charcoal)]/35">
        <span class="hero-hl">AI 工程师</span>和<span class="hero-hl">创作者</span>
      </p>
    </div>
  </section>

  <!-- 卡片网格：所有作品混合展示（3 篇真实文章 + 视频/程序占位）-->
  <section class="max-w-[1200px] mx-auto px-4 py-12 md:py-16 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {sorted.map(article => (
        <ArticleCard article={article} />
      ))}
      <PlaceholderCard category="video" />
      <PlaceholderCard category="program" />
    </div>
  </section>
</Layout>

<style>
  .hero-section {
    height: calc(100vh - 64px);
    height: calc(100dvh - 64px);
    min-height: 480px;
  }
  @media (max-width: 768px) {
    .hero-section {
      height: calc(100vh - 56px);
      height: calc(100dvh - 56px);
      min-height: 380px;
    }
  }
  /* Hero 高亮：相对父级字号大一档，深炭黑，字距收紧 */
  .hero-hl {
    color: var(--color-charcoal);
    font-weight: 600;
    letter-spacing: -0.01em;
    font-size: 1.2em;
  }
</style>

<script>
  // 标签页切回前台时重启 hero 视频，避免 Chrome/Safari 后台后停在某帧
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) {
      const v = document.getElementById('heroBgVideo') as HTMLVideoElement | null;
      if (v) v.play().catch(() => {});
    }
  });
</script>

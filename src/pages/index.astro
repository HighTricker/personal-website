---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import PlaceholderCard from '../components/PlaceholderCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.hidden);
const sorted = articles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="AI 工程师和创作者">
  <!-- Hero（方案 G：颜色对比 + 高亮字大一档）-->
  <section class="max-w-[800px] mx-auto px-4 py-16 md:py-24 text-center">
    <p class="text-3xl md:text-5xl mb-4 leading-tight text-[var(--color-charcoal)]/35">
      您好，我是 <span class="hero-hl">鲁家琪</span>
    </p>
    <p class="text-xl md:text-2xl text-[var(--color-charcoal)]/35">
      <span class="hero-hl">AI 工程师</span>和<span class="hero-hl">创作者</span>
    </p>
  </section>

  <!-- 卡片网格：所有作品混合展示（3 篇真实文章 + 视频/程序占位）-->
  <section class="max-w-[1200px] mx-auto px-4 py-8 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {sorted.map(article => (
        <ArticleCard article={article} />
      ))}
      <PlaceholderCard category="video" />
      <PlaceholderCard category="program" />
    </div>
  </section>
</Layout>

<style>
  /* Hero 高亮（方案 G）：相对父级字号大一档（约 Tailwind 一档），深炭黑，字距收紧 */
  .hero-hl {
    color: var(--color-charcoal);
    font-weight: 600;
    letter-spacing: -0.01em;
    font-size: 1.2em;
  }
</style>

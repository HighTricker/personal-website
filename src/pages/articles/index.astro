---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.hidden);
const sorted = articles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout
  title="文章"
  description="鲁家琪的文章列表 — 读书笔记、个人成长、求职经验、学术论文。"
>
  <section class="max-w-[1200px] mx-auto px-4 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl mb-8 text-center">文章</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {sorted.map(article => (
        <ArticleCard article={article} />
      ))}
    </div>
  </section>
</Layout>

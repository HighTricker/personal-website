---
import type { CollectionEntry } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import { t, localizePath, type Locale } from '../i18n';

interface Props {
  article: CollectionEntry<'articles'>;
  locale?: Locale;
}

const { article, locale = 'zh' } = Astro.props;
const i18n = t(locale);

// 自动找封面图：
// 1) frontmatter cover 字段且文件存在 → 用它
// 2) 否则扫描 public/covers/<slug>.{jpg,jpeg,png,webp,gif} 找第一个存在的
// 3) 都没有 → 显示渐变占位
function resolveCover(slug: string, frontmatterCover: string | null | undefined): string | null {
  const coversDir = path.join(process.cwd(), 'public', 'covers');
  const exts = ['jpg', 'jpeg', 'png', 'webp', 'gif'];

  if (frontmatterCover) {
    const fileName = frontmatterCover.replace(/^\/covers\//, '');
    if (fs.existsSync(path.join(coversDir, fileName))) {
      return frontmatterCover;
    }
  }

  for (const ext of exts) {
    const filePath = path.join(coversDir, `${slug}.${ext}`);
    if (fs.existsSync(filePath)) {
      return `/covers/${slug}.${ext}`;
    }
  }

  return null;
}

const coverPath = resolveCover(article.id, article.data.cover);

function formatDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}

// 英文版优先用 title_en（如果有），否则 fallback 到中文 title
const data = article.data as { title: string; title_en?: string; summary: string; date: Date; cover?: string | null };
const displayTitle = locale === 'en' && data.title_en ? data.title_en : data.title;
const articleHref = localizePath(`/articles/${article.id}`, locale);
---

<a
  href={articleHref}
  class="block border border-[var(--color-parchment)] rounded-2xl p-4 hover:border-[var(--color-amethyst)] transition-colors no-underline"
>
  <!-- 封面图（16:9 比例 + 自己的圆角，留卡片 padding 不紧贴）-->
  <div class="aspect-video rounded-xl bg-gradient-to-br from-[var(--color-parchment)] to-[var(--color-cream)] overflow-hidden">
    {coverPath && (
      <img
        src={coverPath}
        alt={displayTitle}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    )}
  </div>

  <!-- 内容区 -->
  <div class="pt-4">
    <h2 class="text-lg mb-2 leading-snug">{displayTitle}</h2>
    <p class="text-sm text-[var(--color-charcoal)]/70 leading-relaxed mb-4 line-clamp-3">
      {data.summary}
    </p>
    <div class="flex items-center gap-2 text-xs">
      <span class="text-[var(--color-charcoal)]/50">{formatDate(data.date)}</span>
      <span class="text-[var(--color-charcoal)]/30">·</span>
      <span class="cat-text cat-article">{i18n.card.article}</span>
      {locale === 'en' && i18n.article.chineseOnly && (
        <>
          <span class="text-[var(--color-charcoal)]/30">·</span>
          <span class="text-[var(--color-charcoal)]/40">{i18n.article.chineseOnly}</span>
        </>
      )}
    </div>
  </div>
</a>

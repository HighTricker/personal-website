---
import { t, type Locale } from '../i18n';

interface Props {
  category: 'video' | 'program';
  locale?: Locale;
}

const { category, locale = 'zh' } = Astro.props;
const i18n = t(locale);

const categoryConfig = {
  video: {
    label: i18n.card.video,
    className: 'cat-video',
    title: i18n.card.videoTitle,
    description: i18n.card.comingSoon,
  },
  program: {
    label: i18n.card.program,
    className: 'cat-program',
    title: i18n.card.programTitle,
    description: i18n.card.comingSoon,
  },
};

const cfg = categoryConfig[category];
---

<article class="block border border-[var(--color-parchment)] rounded-2xl p-4 opacity-60">
  <!-- 封面占位（16:9 比例 + 自己的圆角，柔和渐变）-->
  <div class="aspect-video rounded-xl bg-gradient-to-br from-[var(--color-parchment)] to-[var(--color-cream)]"></div>

  <!-- 内容区 -->
  <div class="pt-4">
    <h2 class="text-lg mb-2 leading-snug">{cfg.title}</h2>
    <p class="text-sm text-[var(--color-charcoal)]/70 leading-relaxed mb-4 line-clamp-3">
      {cfg.description}
    </p>
    <div class="flex items-center gap-2 text-xs">
      <span class="text-[var(--color-charcoal)]/30">—</span>
      <span class="text-[var(--color-charcoal)]/30">·</span>
      <span class={`cat-text ${cfg.className}`}>{cfg.label}</span>
    </div>
  </div>
</article>

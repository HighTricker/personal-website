---
import { SITE } from '../data/site';
---

<nav class="border-b border-[var(--color-parchment)]">
  <div class="px-4 md:px-6 py-3 flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
    <!-- 左侧组：头像 + 名字 + EN/中切换 -->
    <div class="flex items-center gap-3 md:gap-4">
      <a href="/" class="flex items-center gap-2 no-underline">
        <img
          src={SITE.assets.avatar}
          alt={SITE.name}
          class="w-7 h-7 md:w-9 md:h-9 rounded-lg object-cover"
          width="36"
          height="36"
        />
        <span class="text-sm md:text-base text-[var(--color-charcoal)]">{SITE.name}</span>
      </a>

      <button
        type="button"
        class="text-xs md:text-sm text-[var(--color-charcoal)] opacity-60 hover:opacity-100 cursor-pointer"
        title="English version coming soon"
      >
        EN / 中
      </button>
    </div>

    <!-- 右侧：导航链接 + 社交图标 -->
    <div class="flex items-center gap-3 md:gap-4">
      <a href="/about" class="text-xs md:text-sm text-[var(--color-charcoal)] hover:text-[var(--color-amethyst)]">关于我</a>
      <a href="/articles" class="text-xs md:text-sm text-[var(--color-charcoal)] hover:text-[var(--color-amethyst)]">文章</a>

      <a href={SITE.social.x} target="_blank" rel="noopener" aria-label="X" class="text-[var(--color-charcoal)] opacity-60 hover:opacity-100 transition-opacity">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="md:w-[18px] md:h-[18px]">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>

      <a href={SITE.social.xiaohongshu} target="_blank" rel="noopener" aria-label="小红书" class="opacity-70 hover:opacity-100 transition-opacity">
        <img src="/icons/xiaohongshu.svg" alt="小红书" width="18" height="18" class="w-4 h-4 md:w-[18px] md:h-[18px] block" />
      </a>

      <a href={`mailto:${SITE.email}`} aria-label="邮箱" class="text-[var(--color-charcoal)] opacity-60 hover:opacity-100 transition-opacity">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="md:w-[18px] md:h-[18px]">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>
    </div>
  </div>
</nav>
